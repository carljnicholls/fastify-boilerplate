{
    "name": "fastify-boilerplate",
    "version": "0.0.1",
    "description": "",
    "main": "index.js",
    "keywords": [
        "boilerplate",
        "fastify",
        "Bruno",
        "jest",
        "openapi"
    ],
    "author": "Carl James Nicholls",
    "license": "MIT",
    "type": "module",
    "engines": {
        "node": ">=25"
    },
    "scripts": {
        "clean": "rimraf dist",
        "build": "tsc --build tsconfig.json ",
        "start": "node dist/index.js",
        "dev-start": "rimraf dist && tsc --build tsconfig.json && node dist/index.js",
        "test": "vitest",
        "test-coverage": "vitest --coverage",
        "integration": "cd ./src/__tests__/integration && bru run",
        "integration-coverage": "cd ./src/__tests__/integration && bru run --reporter-junit ../../../coverage/bruno-results.xml"
    },
    "dependencies": {
        "@fastify/autoload": "^6.3.1",
        "@fastify/cors": "^11.2.0",
        "@fastify/env": "^6.0.0",
        "@fastify/postgres": "^6.0.2",
        "@fastify/redis": "^7.2.0",
        "@fastify/swagger": "^9.7.0",
        "@fastify/swagger-ui": "^5.2.6",
        "@fastify/type-provider-typebox": "^6.1.0",
        "@sinclair/typebox": "^0.34.49",
        "fastify": "^5.8.5",
        "mqtt": "^5.15.1",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@jest/globals": "^30.3.0",
        "@types/mqtt": "^0.0.34",
        "@types/node": "^25.6.0",
        "@types/pg": "^8.20.0",
        "@usebruno/cli": "^3.3.0",
        "@vitest/coverage-v8": "^4.1.5",
        "@vitest/ui": "^4.1.5",
        "fastify-cli": "^8.0.0",
        "memfs": "^4.57.2",
        "rimraf": "^6.1.3",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    }
}
