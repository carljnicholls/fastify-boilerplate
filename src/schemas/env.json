{
    "type": "object",
    "required": [
        "POSTGRES_USER",
        "POSTGRES_HOST",
        "POSTGRES_DB",
        "POSTGRES_PASSWORD",
        "POSTGRES_PORT"
    ],
    "properties": {
        "NODE_ENV": {
            "type": "string",
            "enum": ["development", "production", "test"],
            "default": "development"
        },
        "APP_PORT": {
            "type": "integer",
            "default": 8080
        },
        "POSTGRES_USER": {
            "type": "string",
            "description": "PostgreSQL user"
        },
        "POSTGRES_HOST": {
            "type": "string",
            "description": "PostgreSQL host"
        },
        "POSTGRES_DB": {
            "type": "string",
            "description": "PostgreSQL database name"
        },
        "POSTGRES_PASSWORD": {
            "type": "string",
            "description": "PostgreSQL password"
        },
        "POSTGRES_PORT": {
            "type": "string",
            "description": "PostgreSQL port"
        },
        "REDIS_HOST": {
            "type": "string",
            "default": "redis"
        },
        "REDIS_PORT": {
            "type": "integer",
            "default": 6379
        },
        "REDIS_CACHE_TIMEOUT": {
            "type": "integer",
            "default": 600
        }
    }
}
